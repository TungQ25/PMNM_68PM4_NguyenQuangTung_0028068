# Thư mục public — mọi request đi qua index.php (router MVC)

DirectoryIndex index.php index.html

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Không khai báo RewriteBase → Apache tự lấy theo thư mục public (ổn với XAMPP).
    # Chỉ bật khi rewrite lỗi, ví dụ virtual host document root = public:
    # RewriteBase /

    # Không rewrite file/thư mục thật (css, ảnh, index.php...)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Trang chủ: /
    RewriteRule ^$ index.php [L,QSA]

    # URL còn lại → ?url=controller/action/...
    RewriteRule ^(.+)$ index.php?url=$1 [L,QSA]
</IfModule>

# Chặn truy cập file ẩn (.htaccess, .env...)
<IfModule mod_authz_core.c>
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>
</IfModule>
