Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Luôn phục vụ tài nguyên tĩnh trực tiếp
    RewriteRule ^(css|js|images|fonts|assets)/ - [L]

    # Không rewrite file/thư mục thật (css, ảnh, index.php...)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Trang chủ: /
    RewriteRule ^$ index.php [L,QSA]

    # URL còn lại → ?url=controller/action/...
    RewriteRule ^(.+)$ index.php?url=$1 [L,QSA]
</IfModule>

# Chặn truy cập file ẩn (.htaccess, .env...)
<IfModule mod_authz_core.c>
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>
</IfModule>
